# Gemini API Key - Get this from Google AI Studio (https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Chatbot API endpoint — Flowise prediction URL
# Found in Flowise dashboard: Chatflows > your flow > API > Prediction endpoint
NEXT_PUBLIC_CHATBOT_API_URL=https://your-flowise-host/api/v1/prediction/your-flow-id

# EmailJS credentials — Found at https://dashboard.emailjs.com
# Service ID: Email Services tab
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id

# Template ID: Email Templates tab
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# Public Key: Account > API Keys
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
